{
  "name": "gabriel-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "netlify dev",
    "dev:vite": "vite",
    "dev:directing": "VITE_PORTFOLIO_MODE=directing vite",
    "dev:postprod": "VITE_PORTFOLIO_MODE=postproduction vite",
    "build": "vite build",
    "build:directing": "VITE_PORTFOLIO_MODE=directing vite build",
    "build:postprod": "VITE_PORTFOLIO_MODE=postproduction vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "instagram-studio": "cd scripts/instagram-studio && npm run dev",
    "instagram-studio:install": "cd scripts/instagram-studio && npm install",
    "instagram-studio:build": "cd scripts/instagram-studio && npm run build"
  },
  "dependencies": {
    "@netlify/functions": "^2.8.1",
    "@remix-run/router": "1.15.3",
    "airtable": "^0.12.2",
    "cloudinary": "^2.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "6.22.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/ui": "^4.0.14",
    "dotenv": "^17.2.3",
    "netlify-plugin-cache": "^1.0.3",
    "sharp": "^0.34.5",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.14"
  }
}